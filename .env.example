# Copy this file to .env and fill in the real values from your secret store.
# Never commit the populated .env — .gitignore already excludes it.
#
# These are read by the local upload scripts in scripts/*.mjs:
#   - scripts/upload-logo.mjs
#   - scripts/upload-monthly-banners.mjs
#   - scripts/upload-banners-from-folder.mjs
#   - scripts/upload-to-r2.mjs
#   - scripts/upload-reels.mjs
#   - scripts/process-creatives.mjs
#
# They are NOT read by Vercel-deployed code — production gets the same
# values from the Vercel project's Environment Variables UI.

# ─── Cloudflare R2 (S3-compatible) ───────────────────────────────────────
# From the Cloudflare dashboard → R2 → Manage R2 API Tokens.
R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<32-char access key id>
R2_SECRET_ACCESS_KEY=<64-char secret access key>
R2_BUCKET_NAME=<bucket name, e.g. turboloop-assets>
# Public read URL prefix — the r2.dev hostname or your custom domain.
# Do NOT include a trailing slash.
R2_PUBLIC_URL=https://pub-1d13f4e7ccfa4575bc04b75045f1b1b1.r2.dev

# ─── Database (Neon Postgres) — only needed if running scripts that
#     write directly, e.g. scripts/seed.mjs or fix-* scripts. The
#     upload scripts above don't need it. ───────────────────────────────
# DATABASE_URL=postgres://...

# ─── Telegram (production-only — set in Vercel, NOT in local .env) ──────
# These power the cron-master broadcasts. Do NOT commit real values.
# TELEGRAM_BOT_TOKEN=<bot-father-token>
# TELEGRAM_CHANNEL=@TurboLoop_Official        # public English broadcast
# TELEGRAM_CHAT=@TurboLoop_Chat               # public English discussion
# TELEGRAM_SUBMISSIONS_CHAT=<-100xxxx>        # private ops group for content submissions
# TELEGRAM_SUPPORT_CHAT=<-100xxxx>            # private ops group for event apps + support
# TELEGRAM_GERMAN_CHAT=-1003811032556         # @TurboLoopDach — daily 11:00 UTC German cron target
