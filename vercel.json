{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist/public",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/rss.xml", "destination": "/api/rss" },
    {
      "source": "/(blog|reels|films|topic|vs|learn|ecosystem)/(.*)",
      "destination": "/api/social-meta",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(bot|Bot|BOT|Telegram|WhatsApp|facebook|Facebook|Twitter|twitter|LinkedIn|linkedin|Discord|discord|Slack|slack|crawler|Crawler|spider|Spider|preview|Preview|SkypeUriPreview|YandexBot|baidu|DuckDuckBot|Applebot).*"
        }
      ]
    },
    { "source": "/((?!api/|assets/|.*\\..*).*)", "destination": "/index.html" }
  ],
  "trailingSlash": false,
  "functions": {
    "api/trpc/[trpc].js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/cron/publish-blog.js": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/sitemap.js": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/og.js": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/og-zoom.js": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/rss.js": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/social-meta.js": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/monitor.js": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/cron/master.js": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "crons": [
    {
      "path": "/api/cron/master",
      "schedule": "0 4 * * *"
    }
  ]
}
